---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import es from '../i18n/es.json';

const c = es.contacto;
const endpoint = import.meta.env.PUBLIC_FORM_ENDPOINT?.trim();
const contacts = es.cta.contacts;
---

<Base title={c.meta.title} description={c.meta.description}>
  <Header />
  <main class="contact-page">
    <header class="wrap contact-head">
      <div class="sec-label">{c.label}</div>
      <h1>{c.title}</h1>
      <p class="lead">{c.lead}</p>
    </header>
    <section class="wrap contact-grid">
      <div class="contact-main">
        {endpoint ? (
          <form class="contact-form" method="POST" action={endpoint} data-contact-form data-endpoint={endpoint}>
            <div class="form-grid">
              <label>{c.form.name}*<input type="text" name="nombre" autocomplete="name" required /></label>
              <label>{c.form.company}*<input type="text" name="empresa" autocomplete="organization" required /></label>
              <label>{c.form.email}*<input type="email" name="email" autocomplete="email" required /></label>
              <label>{c.form.phone}<input type="tel" name="telefono" autocomplete="tel" /></label>
            </div>
            <label>{c.form.process}*<textarea name="proceso" rows="5" placeholder={c.form.placeholder} required></textarea></label>
            <label class="hp" aria-hidden="true">No rellenar este campo<input type="text" name="_gotcha" tabindex="-1" autocomplete="off" /></label>
            <label class="privacy-check"><input type="checkbox" name="rgpd" value="aceptada" required /><span>{c.form.privacyPre} <a href="/privacidad/">{c.form.privacyLink}</a>.</span></label>
            <button class="pill" type="submit" data-submit data-idle={c.form.submit} data-sending={c.form.sending}>{c.form.submit}</button>
            <p class="form-error" data-form-error role="alert" hidden>No se ha podido enviar. Escríbenos a <a href="mailto:ingenieria@jsp-automation.es">ingenieria@jsp-automation.es</a> o llámanos al <a href="tel:+34696199024">+34 696 199 024</a>.</p>
          </form>
        ) : (
          <div class="contact-fallback" data-contact-fallback>
            <h2>{c.fallbackTitle}</h2><p>{c.fallbackText}</p>
            <p><a href="mailto:ingenieria@jsp-automation.es">ingenieria@jsp-automation.es</a><br /><a href="tel:+34696199024">+34 696 199 024</a></p>
          </div>
        )}
        <template id="contact-success"><div class="contact-success" role="status"><h2>{c.success.title}</h2><p>{c.success.text}</p></div></template>
      </div>
      <aside class="contact-aside">
        <h2>{c.afterTitle}</h2>
        <ol>{c.steps.map((step) => <li>{step}</li>)}</ol>
        <div class="contact-direct">
          {contacts.map((item) => <div class="ci"><span>{item.label}</span>{item.label === 'Teléfono' ? <b><a href="tel:+34696199024">{item.value}</a></b> : item.label === 'Email' ? <b><a href="mailto:ingenieria@jsp-automation.es">{item.value}</a></b> : <b>{item.value}</b>}</div>)}
        </div>
        <p class="contact-note">{c.note}</p>
      </aside>
    </section>
  </main>
  <Footer note={es.footer.note} copyright={es.footer.copyright} />
  <script>
    const form = document.querySelector<HTMLFormElement>('[data-contact-form]');
    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const error = form.querySelector<HTMLElement>('[data-form-error]');
      if (!form.checkValidity()) { form.reportValidity(); return; }
      const data = new FormData(form);
      const finish = () => {
        const template = document.querySelector<HTMLTemplateElement>('#contact-success');
        if (template) form.replaceWith(template.content.cloneNode(true));
      };
      if (data.get('_gotcha')) { finish(); return; }
      const button = form.querySelector<HTMLButtonElement>('[data-submit]');
      if (!button) return;
      button.disabled = true; button.textContent = button.dataset.sending || 'Enviando…';
      if (error) error.hidden = true;
      try {
        const response = await fetch(form.dataset.endpoint || '', { method: 'POST', body: data, headers: { Accept: 'application/json' } });
        if (!response.ok) throw new Error('Request failed');
        finish();
      } catch {
        if (error) error.hidden = false;
        button.disabled = false; button.textContent = button.dataset.idle || 'Enviar';
      }
    });
  </script>
</Base>
