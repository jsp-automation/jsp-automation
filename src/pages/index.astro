---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import es from '../i18n/es.json';

import heroImg from '../assets/provisional/hero.jpg';
import awpImg from '../assets/provisional/awp.jpg';
import cellImg from '../assets/provisional/cell.jpg';
import glueImg from '../assets/provisional/glue2.jpg';

const navItems = [
  { label: es.nav.soluciones, href: '/soluciones/' },
  { label: es.nav.proyectos, href: '#caso' },
  { label: es.nav.metodo, href: '/como-trabajamos/' },
  { label: es.nav.empresa, href: '/empresa/' },
];
---

<Base title={es.meta.title} description={es.meta.description}>
  <Header navItems={navItems} ctaLabel={es.nav.cta} ctaHref="/contacto/" />

  <main id="contenido">
  <!-- ACTO I : mundo oscuro continuo -->
  <div class="act-dark" id="top">
    <section class="hero">
      <div class="hero-media">
        <Image src={heroImg} alt={es.hero.imageAlt} widths={[760, 1200, 1298]} sizes="100vw" loading="eager" fetchpriority="high" quality={78} />
      </div>
      <div class="hero-inner">
        <div class="wrap">
          <div class="hero-eyebrow">{es.hero.eyebrow}</div>
          <h1>
            <span class="l"><i>{es.hero.titleLine1}</i></span>
            <span class="l"><i>{es.hero.titleLine2}</i></span>
          </h1>
          <p class="hero-sub">{es.hero.sub}</p>
          <div class="hero-cta">
            <a class="pill" href="/contacto/">{es.hero.ctaPrimary} <span class="arr">→</span></a>
            <a class="pill pill-ghost" href="/soluciones/">{es.hero.ctaSecondary}</a>
          </div>
        </div>
      </div>
    </section>

    <section class="statement">
      <div class="ghost" aria-hidden="true" data-ghost>{es.statement.ghost}</div>
      <div class="wrap statement-inner reveal">
        <h2>{es.statement.titlePre}<br>{es.statement.titlePost} <span class="k">{es.statement.titleAccent}</span>.</h2>
        <p>{es.statement.lead}</p>
        <div class="traits">
          {es.statement.traits.map((tr) => (
            <div class="trait"><div class="t">{tr.t}</div><p>{tr.p}</p></div>
          ))}
        </div>
      </div>
    </section>

    <div class="float-product reveal">
      <div class="img-wrap" data-float>
        <Image src={awpImg} alt={es.floatProduct.imageAlt} widths={[520, 800, 1000]} sizes="(max-width: 720px) 72vw, 620px" quality={80} />
      </div>
      <div class="cap">{es.floatProduct.cap}</div>
    </div>

    <section class="products" id="soluciones">
      <div class="wrap">
        <div class="head reveal">
          <h2>{es.products.titleLine1}<br>{es.products.titleLine2}</h2>
          <p class="lead">{es.products.lead}</p>
        </div>
        {es.products.items.map((p, index) => {
          const href = index === 0 || index === 2
            ? '/soluciones/paletizado/'
            : index === 1
              ? '/soluciones/automatizacion-a-medida/'
              : index === 3
                ? '/soluciones/despaletizado/'
                : '/soluciones/control-de-calidad/';
          const Tag = href ? 'a' : 'div';
          return <Tag class:list={["prow", "reveal", { "prow-static": !href }]} href={href}>
            <h3>{p.name}</h3>
            <p>{p.desc}</p>
            {href && <span class="go" aria-hidden="true">→</span>}
          </Tag>;
        })}
      </div>
    </section>

    <div class="wrap">
      <div class="reel reveal">
        <Image src={cellImg} alt={es.reel.imageAlt} widths={[760, 1024]} sizes="(max-width: 1200px) 100vw, 1160px" quality={78} />
        <div class="shade"></div>
        <div class="play" aria-hidden="true"></div>
        <div class="cap"><span>{es.reel.kicker}</span><b>{es.reel.title}</b></div>
      </div>
      <div class="reel-note reveal">{es.reel.note}</div>
    </div>
    <div class="tail"></div>
  </div>

  <!-- ACTO II : lienzo claro editorial -->
  <div class="act-light">
    <section class="wrap method" id="metodo">
      <div class="reveal">
        <div class="sec-label">{es.method.label}</div>
        <h2>{es.method.titleLine1}<br>{es.method.titleLine2}</h2>
        <p class="lead">{es.method.lead}</p>
      </div>
      <div class="steps">
        {es.method.steps.map((s) => (
          <div class="step reveal"><span class="n">{s.n}</span><h3>{s.h}</h3><p>{s.p}</p></div>
        ))}
      </div>
      <div class="method-claims reveal">
        {es.method.claims.map((c) => (
          <span><b>{c.b}</b>{c.rest}</span>
        ))}
      </div>
      <a class="plink method-link reveal" href="/como-trabajamos/">Ver el método completo <span class="arr">→</span></a>
    </section>

    <section class="wrap case" id="caso">
      <div class="media reveal">
        <Image src={glueImg} alt={es.case.imageAlt} widths={[600, 884]} sizes="(max-width: 860px) 100vw, 620px" quality={80} />
      </div>
      <div class="reveal">
        <div class="sec-label">{es.case.label}</div>
        <h2>{es.case.title}</h2>
        <p class="lead">{es.case.lead}</p>
        <div class="case-data">
          {es.case.data.map((d) => (
            <div class="cd">
              {'count' in d && d.count !== undefined
                ? <b data-count={d.count} data-prefix={d.prefix} data-suffix={d.suffix}>{d.prefix}{d.count}{d.suffix}</b>
                : <b>{d.static}</b>}
              <span>{d.label}</span>
            </div>
          ))}
        </div>
        <q>{es.case.quote}</q>
      </div>
    </section>

    <section class="wrap cta-final" id="contacto">
      <div class="reveal">
        <div class="sec-label">{es.cta.label}</div>
        <h2>{es.cta.title}</h2>
        <p class="lead">{es.cta.lead}</p>
        <a class="pill" href="/contacto/">{es.cta.button} <span class="arr">→</span></a>
        <div class="cta-note">{es.cta.note}</div>
      </div>
      <div class="contact-row reveal">
        {es.cta.contacts.map((c) => (
          <div class="ci"><span>{c.label}</span><b>{c.value}</b></div>
        ))}
      </div>
    </section>

  </div>
  </main>
  <Footer note={es.footer.note} />
</Base>
