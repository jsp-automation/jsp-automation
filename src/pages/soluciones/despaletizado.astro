---
import Solution from '../../layouts/Solution.astro';
import es from '../../i18n/es.json';
import cellImg from '../../assets/provisional/cell.jpg';
const content = es.solutions.despaletizado;
---
<Solution content={content} heroImage={cellImg}>
  <div slot="specific">
    <section class="wrap method solution-section"><div class="reveal"><div class="sec-label">{es.solutions.common.system}</div><h2>{content.operation.title}</h2></div><div class="steps">{content.operation.steps.map((step) => <div class="step reveal"><span class="n">{step.n}</span><h3>{step.h}</h3><p>{step.p}</p></div>)}</div></section>
    <section class="wrap solution-section prose-block reveal"><div class="sec-label">{es.solutions.common.development}</div><h2>{content.status.title}</h2><p class="lead">{content.status.text}</p></section>
  </div>
</Solution>
