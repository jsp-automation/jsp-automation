---
import { Image } from 'astro:assets';
import Solution from '../../layouts/Solution.astro';
import es from '../../i18n/es.json';
import glueImg from '../../assets/provisional/glue2.jpg';
const content = es.solutions.automatizacionMedida;
---
<Solution content={content} heroImage={glueImg}>
  <section slot="specific" class="wrap case solution-product">
    <div class="media reveal"><Image src={glueImg} alt={content.caseStudy.imageAlt} widths={[600, 900]} sizes="(max-width: 860px) 100vw, 50vw" quality={82} /></div>
    <div class="reveal"><div class="sec-label">Caso real</div><h2>{content.caseStudy.title}</h2><p class="lead">{content.caseStudy.intro}</p><ul class="feature-list">{content.caseStudy.features.map((feature) => <li>{feature}</li>)}</ul></div>
  </section>
</Solution>
