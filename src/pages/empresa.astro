---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import es from '../i18n/es.json';
import heroImg from '../assets/provisional/cell.jpg';
import glueImg from '../assets/provisional/glue2.jpg';

const c = es.empresa;
const navItems = [
  { label: es.nav.soluciones, href: '/soluciones/' },
  { label: es.nav.proyectos, href: '/#caso' },
  { label: es.nav.metodo, href: '/como-trabajamos/' },
  { label: es.nav.empresa, href: '/empresa/' },
];
---
<Base title={c.meta.title} description={c.meta.description}>
  <Header navItems={navItems} ctaLabel={es.nav.cta} ctaHref="/contacto/" />
  <div class="act-dark solution-act" id="top">
    <section class="hero solution-hero">
      <div class="hero-media"><Image src={heroImg} alt={c.hero.imageAlt} widths={[760, 1200, 1600]} sizes="100vw" loading="eager" fetchpriority="high" quality={80} /></div>
      <div class="hero-inner"><div class="wrap">
        <div class="hero-eyebrow">{c.hero.eyebrow}</div>
        <h1><span class="l"><i>{c.hero.title}</i></span></h1>
        <p class="hero-sub">{c.hero.sub}</p>
        <div class="hero-cta"><a class="pill" href="/contacto/">{c.hero.primary} <span class="arr">→</span></a><a class="pill pill-ghost" href="/como-trabajamos/">{c.hero.secondary}</a></div>
      </div></div>
    </section>
  </div>
  <main class="act-light solution-light editorial-page" id="contenido">
    <section class="wrap solution-section prose-block"><div class="sec-label">{c.experience.label}</div><h2>{c.experience.title}</h2><p class="lead">{c.experience.text}</p></section>
    <section class="wrap case company-origin">
      <div class="media reveal"><Image src={glueImg} alt={c.origin.imageAlt} widths={[600, 884]} sizes="(max-width: 860px) 100vw, 620px" quality={80} /></div>
      <div class="reveal"><div class="sec-label">{c.origin.label}</div><h2>{c.origin.title}</h2>{c.origin.paragraphs.map((p) => <p>{p}</p>)}<div class="case-data">{c.origin.data.map((d) => <div class="cd"><b>{d.value}</b><span>{d.label}</span></div>)}</div></div>
    </section>
    <section class="wrap solution-section services"><div class="sec-label">{c.services.label}</div><h2>{c.services.title}</h2><p class="lead">{c.services.intro}</p><div class="service-list">{c.services.items.map((item) => <div class="service-item reveal">{item}</div>)}</div><p class="lead service-closing">{c.services.closing}</p></section>
    <section class="wrap solution-section prose-block"><div class="sec-label">{c.proximity.label}</div><h2>{c.proximity.title}</h2><p class="lead">{c.proximity.text}</p></section>
    <section class="wrap solution-section prose-block criterion"><div class="sec-label">{c.criterion.label}</div><h2>{c.criterion.title}</h2><p class="lead">{c.criterion.text}</p><q>{c.criterion.quote}</q></section>
    <section class="wrap cta-final cta-compact"><div class="reveal"><h2>{c.cta.title}</h2><p class="lead">{c.cta.text}</p><a class="pill" href="/contacto/">{c.cta.button} <span class="arr">→</span></a></div></section>
  </main>
  <Footer note={es.footer.note} copyright={es.footer.copyright} />
</Base>
