---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  noindex?: boolean;
}

const { title, description, noindex = false } = Astro.props;
const canonicalHref = new URL(Astro.url.pathname, Astro.site).href;
const siteHref = new URL('/', Astro.site).href;
const organizationId = `${siteHref}#organization`;
const ogImageHref = new URL('/og.jpg', Astro.site).href;
const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': organizationId,
  name: 'JSP Automation',
  url: siteHref,
  logo: new URL('/icon-512.png', Astro.site).href,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Arnedo',
    addressRegion: 'La Rioja',
    addressCountry: 'ES',
  },
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: '+34 696 199 024',
    email: 'ingenieria@jsp-automation.es',
    contactType: 'sales',
  },
  areaServed: 'ES',
};
const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'JSP Automation',
  url: siteHref,
};
---

<!doctype html>
<html lang="es" dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#F6F6F4" />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonicalHref} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalHref} />
    <meta property="og:site_name" content="JSP Automation" />
    <meta property="og:image" content={ogImageHref} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageHref} />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <script type="application/ld+json" set:html={JSON.stringify(organizationJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />
    <slot name="head" />
  </head>
  <body>
    <slot />
    <script>
      import { init } from '../scripts/motion';

      init();
    </script>
  </body>
</html>
