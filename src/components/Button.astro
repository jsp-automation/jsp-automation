---
interface Props {
  variant?: 'primary' | 'ghost';
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  className?: string;
  ariaLabel?: string;
  showArrow?: boolean;
}

const {
  variant = 'primary',
  href,
  type = 'button',
  className = '',
  ariaLabel,
  showArrow = variant === 'primary',
} = Astro.props;

const classes = ['btn', variant === 'ghost' ? 'btn-ghost' : '', className].filter(Boolean).join(' ');
---

{href ? (
  <a class={classes} href={href} aria-label={ariaLabel}>
    <slot />
    {showArrow && <span class="arr" aria-hidden="true">→</span>}
  </a>
) : (
  <button class={classes} type={type} aria-label={ariaLabel}>
    <slot />
    {showArrow && <span class="arr" aria-hidden="true">→</span>}
  </button>
)}
