---
import { Image } from 'astro:assets';
import jspLogo from '../assets/brand/jsp-logo.png';

interface Props {
  note?: string;
  copyright?: string;
}

const { note = 'Robótica, visión artificial y automatización industrial', copyright = '© 2026 JSP Automation · Arnedo, La Rioja' } = Astro.props;
---

<footer class="site-footer">
  <div class="wrap foot">
    <div class="foot-brand">
      <Image class="footer-logo" src={jspLogo} alt="JSP Automation" />
      <div>{copyright}</div>
    </div>
    <div>{note}</div>
  </div>
</footer>
