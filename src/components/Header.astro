---
import Button from './Button.astro';

interface NavItem {
  label: string;
  href: string;
}

interface Props {
  navItems?: NavItem[];
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  navItems = [
    { label: 'Soluciones', href: '#soluciones' },
    { label: 'Proyectos', href: '#proyectos' },
    { label: 'Cómo trabajamos', href: '#metodo' },
    { label: 'Empresa', href: '#' },
  ],
  ctaLabel = 'Cuéntanos tu proceso',
  ctaHref = '#contacto',
} = Astro.props;
---

<header class="site-header on-light" data-header>
  <div class="wrap nav">
    <a class="brand" href="#top" aria-label="JSP Automation">
      <svg width="34" height="38" viewBox="0 0 34 38" fill="none" aria-hidden="true">
        <path data-logo-ink d="M17 1 L32.5 9.8 V28.2 L17 37 L1.5 28.2 V9.8 Z" stroke="#15161A" stroke-width="2.2" fill="none" class="hex" />
        <path data-logo-ink d="M11 13 v8 a3.2 3.2 0 0 0 6.4 0" stroke="#15161A" stroke-width="2.6" fill="none" stroke-linecap="round" class="j" />
        <path d="M20 24 v-5 a3.5 3.5 0 0 1 3.5 -3.5 H24" stroke="#46BED4" stroke-width="2.6" fill="none" stroke-linecap="round" />
        <circle cx="24.6" cy="15.2" r="1.7" fill="#46BED4" />
      </svg>
      <span class="brand-name">JSP <span>AUTOMATION</span></span>
    </a>
    <nav class="nav-links" aria-label="Principal">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
    <a class="pill pill-nav" href={ctaHref}>{ctaLabel}</a>
    <button class="nav-toggle" type="button" aria-label="Abrir menú" aria-expanded="false" data-menu-toggle>
      <span aria-hidden="true"></span>
    </button>
  </div>
  <nav class="mobile-menu" aria-label="Menú móvil" data-mobile-menu>
    {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    <div class="mobile-cta">
      <Button href={ctaHref}>{ctaLabel}</Button>
    </div>
  </nav>
</header>
