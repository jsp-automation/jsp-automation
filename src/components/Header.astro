---
import { Image } from 'astro:assets';
import jspLogo from '../assets/brand/jsp-logo.png';
import Button from './Button.astro';

interface NavItem {
  label: string;
  href: string;
}

interface Props {
  navItems?: NavItem[];
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  navItems = [
    { label: 'Soluciones', href: '/soluciones/' },
    { label: 'Proyectos', href: '#proyectos' },
    { label: 'Cómo trabajamos', href: '/como-trabajamos/' },
    { label: 'Empresa', href: '/empresa/' },
  ],
  ctaLabel = 'Cuéntanos tu proceso',
  ctaHref = '/contacto/',
} = Astro.props;
---

<header class="site-header on-light" data-header>
  <div class="wrap nav">
    <a class="brand" href="/" aria-label="JSP Automation">
      <Image class="brand-logo" src={jspLogo} alt="" />
      <span class="brand-name">JSP <span>AUTOMATION</span></span>
    </a>
    <nav class="nav-links" aria-label="Principal">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
    <a class="pill pill-nav" href={ctaHref}>{ctaLabel}</a>
    <button class="nav-toggle" type="button" aria-label="Abrir menú" aria-expanded="false" aria-controls="menu-movil" data-menu-toggle>
      <span aria-hidden="true"></span>
    </button>
  </div>
  <nav class="mobile-menu" id="menu-movil" aria-label="Menú móvil" data-mobile-menu>
    {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    <div class="mobile-cta">
      <Button href={ctaHref}>{ctaLabel}</Button>
    </div>
  </nav>
</header>
